# Dawn backend config — copy to `.env` (gitignored) and fill in.
# Read by docker-compose.yml (services/DEPLOY.md) and the migrate step.

# --- Database (Supabase / Postgres) ---
# Without it, services fall back to in-memory (DEV ONLY) and migrations can't run.
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/postgres

# --- Chain / contract (Base Sepolia) ---
CHAIN_ID=84532
RPC_URL=https://sepolia.base.org
NETWORK=base-sepolia
SETTLEMENT_ADDRESS=0xc27C681cE93a63C0987226CDaC7b66232018651E
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
TREASURY_ADDRESS=0x0000000000000000000000000000000000000000

# --- On-chain feature flags (opt-in; default off = dev-safe) ---
# 1 = indexer polls Base for JobEscrowed/JobSettled and flips job status in the DB.
INDEXER_RPC=1
# 1 = api verifies x402 payments on-chain (only needed for the x402 buyer path).
X402_ONCHAIN=0

# --- Settle ownership (avoid double-settle: pick ONE settler) ---
# UNSET  -> proof-service only logs; the AGENT self-settles (the proven path). Recommended.
# SET    -> proof-service settles on-chain with this funded hot key (then run the agent
#           WITHOUT --features onchain so it doesn't also settle).
SETTLEMENT_PRIVATE_KEY=

# --- Dev escape hatch ---
# 1 = job-queue accepts any nodeId without EIP-191 verification. Leave empty for real
# auth (the agent's HELLO_AUTH signing is verified byte-compatible with the coordinator).
AUTH_ALLOW_ALL=
